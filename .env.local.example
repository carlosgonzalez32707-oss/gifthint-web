# ─────────────────────────────────────────────────────────────────────────────
# GiftHint web app — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (server-side only — NOT exposed to the browser) ──────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (browser-safe — NEXT_PUBLIC_ prefix exposes to client bundle) ────
# Use the anon/public key here, NOT the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL used for generating canonical links and OG URLs.
# In development: http://localhost:3000
# In production:  https://gifthint.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Affiliate ─────────────────────────────────────────────────────────────────
# Amazon Associates tag — server-side only, never exposed to the browser.
# Found in: Amazon Associates dashboard → Account Settings → Tracking ID
# Format: yoursite-XX (e.g. gifthint-20 for US, gifthint-21 for UK)
# Leave blank in development — links will still work, just without attribution.
AMAZON_ASSOCIATES_TAG=gifthint-20

# Skimlinks publisher ID — browser-safe (appears in the script URL, not secret).
# Found in: Skimlinks dashboard → Account → Publisher ID
# Leave blank in development to skip loading the script entirely.
NEXT_PUBLIC_SKIMLINKS_PUBLISHER_ID=123456

# ── Email — Resend ────────────────────────────────────────────────────────────
# Resend (resend.com) handles transactional email.
# Free tier: 3,000 emails/month, 100/day — enough for early-stage.
#
# Setup:
#   1. Create a free account at https://resend.com
#   2. Add and verify your sending domain (e.g. gifthint.io) under Domains
#   3. Create an API key under API Keys and paste it here
#   4. Update the `from` address in lib/email.ts to match your verified domain
#
# In development you can use Resend's test domain:
#   from: 'GiftHint <onboarding@resend.dev>'
#   (only delivers to your own Resend-verified email address)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron security ─────────────────────────────────────────────────────────────
# Secret that Vercel Cron attaches as "Authorization: Bearer <secret>" when
# calling /api/cron/send-reminders. The endpoint rejects requests without it.
#
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Copy the same value into your Vercel project environment variables so Vercel
# Cron can authenticate against your endpoint.
CRON_SECRET=replace_with_a_strong_random_secret_hex_string
