{
  "manifest_version": 2,
  "name": "GiftHint — Save Gifts While You Shop",
  "version": "1.1.0",
  "description": "Save products to wishlists on any retailer site. Multiple lists, occasion tagging, and one-click sharing — all from your browser.",

  "browser_specific_settings": {
    "gecko": {
      "id": "gifthint@gifthint.io",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage",
    "identity",
    "tabs",
    "clipboardWrite",
    "scripting",
    "https://gifthint.io/*",
    "https://pxegvviakrjhldtwtobi.supabase.co/*",
    "https://www.googleapis.com/*",
    "<all_urls>"
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "GiftHint",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://gifthint.io/*"
      ],
      "js": ["dist/floating-button.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    "dist/hint-sheet.js",
    "dist/supabase.js",
    "dist/wishlists.js",
    "icons/*.png"
  ]
}
